# ===================================
# LibreKAi 環境設定ファイル（開発・テスト用）
# ===================================
# ⚠️ セキュリティ警告:
# このファイルはテンプレートです。実際の .env ファイルは：
# 1. このファイルをコピーして作成してください
# 2. 全てのプレースホルダーを強力なランダム文字列に置き換えてください
# 3. 絶対にGitリポジトリにコミットしないでください
#
# 本番環境向けの詳細ガイドは .env.production.example を参照してください。
#
# このファイルは緊急復旧用の必須設定のみを含みます。
# その他の設定（DISCOURSE_*, POINTS_API_KEY等）は
# Webインターフェース (/settings) から管理してください。

# -----------------------------------
# 必須設定（起動に必要）
# -----------------------------------

# Database (PostgreSQL) - 必須
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASS=change-this-db-password
DB_NAME=kai

# Security - 必須（32文字以上のランダム文字列を生成してください）
SESSION_SECRET=replace-with-a-32-plus-char-random-secret

# Site Configuration - 必須（緊急復旧用）
SITE_URL=http://localhost:3008
ADMIN_USERNAME=admin

# -----------------------------------
# オプション設定
# -----------------------------------

# Application
NODE_ENV=development
PORT=3008

# CORS（起動時のフォールバック用。本番環境では Web設定推奨）
CORS_ORIGIN=*

# Webhook Token（Webhook機能を使用する場合のみ）
WEBHOOK_TOKEN=replace-with-a-long-random-webhook-token

# External Services（ローカル開発用）
VOICEVOX_URL=http://127.0.0.1:50021
PYTHON_PATH=python3

# -----------------------------------
# Web管理推奨の設定
# -----------------------------------
# 以下の設定は /settings ページから設定することを推奨します：
# - DISCOURSE_URL, DISCOURSE_SECRET (Discourse認証プラグイン用)
# - POINTS_API_KEY (ポイントシステムプラグイン用)
# - SHORT_URL_API_KEY, SHORT_URL_BASE_URL (短縮URL機能用)
# - CSP_ALLOWED_IMG_DOMAINS (Content Security Policy設定)
#
# Web設定を誤った場合でも、このファイルのSITE_URLとADMIN_USERNAMEで
# データベースに直接アクセスして復旧できます。
