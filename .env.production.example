# ===================================
# LibreKAi 本番環境設定テンプレート
# ===================================
# このファイルは本番環境構築時の詳細ガイドです。
# 実際の設定は .env ファイルにコピーして使用してください。
#
# セキュリティ重要: 
# - このファイルはテンプレートです
# - 実際の .env ファイルは絶対にGitに含めないでください
# - 全ての秘密情報を強力なランダム文字列に置き換えてください

# ===================================
# 必須設定（起動に必要）
# ===================================

# -----------------------------------
# Database (PostgreSQL)
# -----------------------------------
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASS=CHANGE_THIS_TO_STRONG_RANDOM_PASSWORD_32_CHARS_MINIMUM
DB_NAME=librekai

# 🔒 セキュリティTips:
# - DB_PASSは32文字以上のランダム文字列を使用
# - 生成例: openssl rand -hex 32

# -----------------------------------
# Security (セッション管理)
# -----------------------------------
SESSION_SECRET=CHANGE_THIS_TO_STRONG_RANDOM_SECRET_64_CHARS_MINIMUM

# 🔒 セキュリティTips:
# - SESSION_SECRETは64文字以上推奨
# - 生成例: openssl rand -hex 64
# - この値が漏洩するとセッションハイジャック可能になります

# -----------------------------------
# Site Configuration
# -----------------------------------
SITE_URL=https://your-domain.com
ADMIN_USERNAME=your_admin_username

# 🔒 セキュリティTips:
# - SITE_URLは実際のドメインに変更（HTTPSを推奨）
# - ADMIN_USERNAMEは予測困難なものを推奨（admin以外）

# ===================================
# オプション設定
# ===================================

# -----------------------------------
# Application
# -----------------------------------
NODE_ENV=production
PORT=3008

# -----------------------------------
# CORS設定
# -----------------------------------
# 起動時のフォールバック用。本番では /settings から設定推奨
CORS_ORIGIN=https://your-domain.com

# 🔒 セキュリティTips:
# - 本番環境では * (ワイルドカード) は使用しない
# - 信頼するドメインのみを明示的に指定

# -----------------------------------
# Webhook Token
# -----------------------------------
# Webhook機能を使用する場合のみ設定
WEBHOOK_TOKEN=CHANGE_THIS_TO_STRONG_RANDOM_TOKEN_64_CHARS_MINIMUM

# 🔒 セキュリティTips:
# - 生成例: openssl rand -hex 64
# - Webhook機能を使用しない場合は削除しても可

# -----------------------------------
# External Services（オプション）
# -----------------------------------
# 以下はローカルで追加サービスを実行する場合のみ設定

# VOICEVOX（音声合成サービス）
# VOICEVOX_URL=http://127.0.0.1:50021

# Python実行パス
# PYTHON_PATH=python3

# ===================================
# Web管理推奨の設定
# ===================================
# 以下の設定は /settings ページから設定することを強く推奨します：
#
# プラグイン関連:
# - DISCOURSE_URL        : Discourse認証連携URL
# - DISCOURSE_SECRET     : Discourse SSO秘密鍵
# - POINTS_API_KEY       : ポイントシステムAPI認証キー
#
# 機能関連:
# - SHORT_URL_API_KEY    : 短縮URL作成API認証キー
# - SHORT_URL_BASE_URL   : 短縮URLベースURL
#
# セキュリティ関連:
# - CSP_ALLOWED_IMG_DOMAINS : Content Security Policyで許可する画像ドメイン
#
# 🔒 これらをWeb管理画面で設定する理由:
# - データベースに暗号化して保存される
# - Web UIで簡単に変更・確認可能
# - .envファイルの管理が簡素化される

# ===================================
# 本番環境チェックリスト
# ===================================
# デプロイ前に以下を確認してください：
#
# [ ] 全ての秘密情報を強力なランダム文字列に変更済み
# [ ] .env ファイルを .gitignore で除外済み
# [ ] HTTPS (TLS/SSL) を有効化済み
# [ ] PostgreSQL接続がセキュアな接続を使用
# [ ] ファイアウォール設定でポートを適切に制限
# [ ] データベースバックアップ戦略を確立
# [ ] ログ監視とアラート設定を完了
# [ ] リバースプロキシ (Nginx/Caddy等) を設定済み
# [ ] セッションストアがPostgreSQLで設定済み
# [ ] CORS_ORIGIN を信頼するドメインのみに制限
# [ ] 管理者アカウントの強力なパスワード設定済み

# ===================================
# トラブルシューティング
# ===================================
# 
# Q: サービスが起動しない
# A: ログを確認 → logs/error.log
#    データベース接続を確認 → psql -h DB_HOST -U DB_USER -d DB_NAME
#
# Q: セッションが保存されない
# A: PostgreSQLのsessionsテーブルが作成されているか確認
#
# Q: 設定を間違えた
# A: Web管理画面 (/settings) から修正可能
#    緊急時はデータベース直接編集: settings テーブル
#
# 詳細: https://github.com/Kaisan10/LibreKAi/blob/main/guide.md
