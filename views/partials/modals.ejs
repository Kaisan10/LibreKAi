                        <div class="settings-section">
                            <h3><i class="fa-solid fa-file-export"></i> エクスポート</h3>
                            <p class="settings-desc">現在開いているチャットをファイルとして保存します。</p>
                            <button id="exportChatBtn" class="btn-secondary full-width">
                                <i class="fa-solid fa-download"></i> Markdownで保存
                            </button>
                        </div>
                    </div>

                    <!-- Developer Panel -->
                    <div class="settings-panel" id="panel-developer">
                        <div class="settings-section settings-section-last">
                            <h3><i class="fa-solid fa-code"></i> デベロッパー</h3>
                            <p class="settings-desc">外部サイト用の埋め込みウィジェットを管理します。</p>
                            <button id="openEmbeddedSitesBtn" class="btn-primary full-width">
                                <i class="fa-solid fa-external-link"></i> 埋め込みサイト管理を開く
                            </button>
                        </div>
                    </div>

                    <!-- Account Panel -->
                    <div class="settings-panel" id="panel-account">
                        <div class="settings-section settings-section-last">
                            <h3><i class="fa-solid fa-user"></i> アカウント</h3>
                            <p class="settings-desc">アカウントやProプランの管理を行います。</p>
                            <button id="settingsCancelProBtn" class="btn-secondary full-width" style="display: none;">
                                <i class="fa-solid fa-ban"></i> 解約する
                            </button>
                            <button id="settingsLogoutBtn" class="btn-danger full-width" style="display: none;">
                                <i class="fa-solid fa-right-from-bracket"></i> ログアウト
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Frame decorations -->
                <div class="settings-frame-top-left"></div>
                <div class="settings-frame-top-right"></div>
                <div class="settings-frame-right"></div>
                <div class="settings-frame-bottom"></div>
                <div class="settings-frame-bottom-left"></div>
                <div class="settings-frame-bottom-right"></div>
            </div>
        </div>
    </div>

    <!-- Tool Selection Modal -->
    <div id="toolSelectionModal" class="modal-overlay hidden">
        <div class="modal-content tool-selection-modal">
            <div class="modal-header">
                <h2><i class="fa-solid fa-screwdriver-wrench"></i> ツールを選択</h2>
                <button id="closeToolSelectionBtn" class="btn-icon-only"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <div class="modal-body">
                <div class="search-bar">
                    <i class="fa-solid fa-search"></i>
                    <input type="text" id="toolSearchInput" placeholder="ツールを検索...">
                </div>
                <div class="divider-md"></div>
                <div id="toolList" class="tool-list">
                    <!-- Tools will be injected by script.js -->
                </div>
            </div>
            <div class="modal-actions">
                <button id="confirmToolSelectionBtn" class="btn-primary">決定</button>
            </div>
        </div>
    </div>

    <!-- Hidden Templates for JS to use -->
    <template id="userMessageTemplate">
        <div class="message user-message">
            <div class="user-message-wrapper">
                <div class="message-content"></div>
                <div class="message-actions-wrapper">
                    <span class="message-timestamp" data-tooltip=""></span>
                    <div class="message-actions">
                        <button class="btn-action copy-btn" data-tooltip="コピー">
                            <i class="fa-regular fa-copy"></i>
                        </button>
                        <button class="btn-action edit-btn" data-tooltip="編集">
                            <i class="fa-solid fa-pen"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </template>

    <template id="aiMessageTemplate">
        <div class="message ai-message">
            <div class="ai-message-wrapper">
                <div class="message-content markdown-body"></div>
                <div class="message-actions-wrapper">
                    <div class="message-actions">
                        <button class="btn-action copy-btn" data-tooltip="コピー">
                            <i class="fa-regular fa-copy"></i>
                        </button>
                        <div class="feedback-actions">
                            <button class="btn-action feedback-btn" data-type="good" data-tooltip="良い回答">
                                <i class="fa-regular fa-thumbs-up"></i>
                            </button>
                            <button class="btn-action feedback-btn" data-type="bad" data-tooltip="悪い回答">
                                <i class="fa-regular fa-thumbs-down"></i>
                            </button>
                        </div>
                        <button class="btn-action regenerate-btn" data-tooltip="再生成">
                            <i class="fa-solid fa-rotate-right"></i>
                        </button>
                        <button class="btn-action message-share-btn" data-tooltip="共有">
                            <i class="fa-solid fa-share-nodes"></i>
                        </button>
                        <button class="btn-action info-btn" data-tooltip="情報">
                            <i class="fa-solid fa-circle-info"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </template>

    <!-- Message Info Modal -->
    <div id="messageInfoModal" class="modal-overlay hidden">
        <div class="modal-content message-info-modal">
            <div class="modal-header">
                <h2><i class="fa-solid fa-circle-info"></i> このメッセージの情報</h2>
                <button id="closeMessageInfoBtn" class="btn-icon-only"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <div class="modal-body">
                <div class="message-info-item">
                    <span class="message-info-label">送信日時</span>
                    <span id="messageInfoTimestamp" class="message-info-value">-</span>
                </div>
                <div class="message-info-item">
                    <span class="message-info-label">モデル</span>
                    <span id="messageInfoModel" class="message-info-value">-</span>
                </div>
                <div class="message-info-item">
                    <span class="message-info-label">生成速度</span>
                    <span id="messageInfoSpeed" class="message-info-value">-</span>
                </div>
            </div>
            <div class="modal-actions">
                <button id="closeMessageInfoOkBtn" class="btn-primary">OK</button>
            </div>
        </div>
    </div>

    <!-- Feedback Reason Modal -->
    <div id="feedbackReasonModal" class="modal-overlay hidden">
        <div class="modal-content">
            <div class="modal-header">
                <h2><i class="fa-solid fa-comment"></i> フィードバックの理由</h2>
                <button id="closeFeedbackReasonBtn" class="btn-icon-only"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <div class="modal-body">
                <p class="settings-desc">どうしてこの評価をされましたか？（任意）</p>
                <textarea id="feedbackReasonText" placeholder="理由を入力..." rows="3"></textarea>
                <div class="feedback-tags-container">
                    <p class="form-label">タグを選択:</p>
                    <div id="feedbackTagsList" class="feedback-tags-list">
                        <!-- Tags will be inserted here -->
                    </div>
                </div>
            </div>
            <div class="modal-actions">
                <button id="skipFeedbackBtn" class="btn-secondary">スキップ</button>
                <button id="submitFeedbackBtn" class="btn-primary">送信</button>
            </div>
        </div>
    </div>

    <!-- Message Share Modal -->
    <div id="messageShareModal" class="modal-overlay hidden">
        <div class="modal-content">
            <div class="modal-header">
                <h2><i class="fa-solid fa-share-nodes"></i> メッセージを共有</h2>
                <button id="closeMessageShareBtn" class="btn-icon-only"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <div class="modal-body">
                <p class="share-desc">このメッセージを共有する方法を選択してください。</p>
                <div class="share-method-buttons">
                    <button id="shareAsImageBtn" class="btn-share-method">
                        <i class="fa-solid fa-image"></i>
                        <span>画像として共有</span>
                    </button>
                    <button id="shareAsUrlBtn" class="btn-share-method">
                        <i class="fa-solid fa-link"></i>
                        <span>URLで共有</span>
                    </button>
                </div>
                <div id="shareImagePreview" class="share-image-preview hidden">
                    <canvas id="shareCanvas"
                        style="max-width: 100%; border: 1px solid var(--border-color); border-radius: var(--radius-md);"></canvas>
                    <button id="downloadShareImageBtn" class="btn-primary">画像をダウンロード</button>
                </div>
                <div id="shareUrlContainer" class="share-url-container hidden">
                    <div class="form-label">共有リンク</div>
                    <div class="url-input-group">
                        <input type="text" id="messageShareUrlInput" readonly class="share-url-input">
                        <button id="copyMessageShareUrlBtn" class="btn-secondary" title="URLをコピー">
                            <i class="fa-regular fa-copy"></i>
                        </button>
                    </div>
                </div>
                <p class="share-note">会話全体を共有するには、チャット共有ボタンをご利用ください。</p>
            </div>
        </div>
    </div>

    <!-- Tag Management Modal -->
    <div id="tagManagementModal" class="modal-overlay hidden">
        <div class="modal-content">
            <div class="modal-header">
                <h2><i class="fa-solid fa-tags"></i> タグを管理</h2>
                <button id="closeTagManagementBtn" class="btn-icon-only"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <div class="modal-body">
                <div class="tag-search-container">
                    <i class="fa-solid fa-search tag-search-icon"></i>
                    <input type="text" id="tagSearchInput" placeholder="タグを検索..." class="tag-search-input">
                </div>
                <div class="selected-tags-container">
                    <p class="form-label">選択中のタグ</p>
                    <div id="selectedTagsList" class="tags-list selected-tags">
                        <!-- Selected tags will be shown here -->
                    </div>
                </div>
                <div class="available-tags-container">
                    <p class="form-label">利用可能なタグ</p>
                    <div id="availableTagsList" class="tags-list">
                        <!-- Tags will be inserted here -->
                    </div>
                    <div class="tag-create-container">
                        <input type="text" id="newTagInput" placeholder="新しいタグ名..." maxlength="20">
                        <button id="createTagBtn" class="btn-secondary"><i class="fa-solid fa-plus"></i> 作成</button>
                    </div>
                </div>
            </div>
            <div class="modal-actions">
                <button id="cancelTagManagementBtn" class="btn-secondary">キャンセル</button>
                <button id="saveTagsBtn" class="btn-primary">保存</button>
            </div>
        </div>
    </div>

    <div id="announcementContainer" class="announcement-container" aria-live="polite" aria-label="お知らせ"></div>

    <!-- Shared Session Menu Dropdown -->
    <div id="sessionMenuDropdown" class="dropdown history-dropdown hidden"></div>

    <!-- Admin: shared setting edit modal (used by システム設定 and ログインと認証) -->
    <div id="admin-setting-modal" class="modal-overlay hidden">
        <div class="modal-content">
            <div class="modal-header">
                <h2 id="admin-setting-modal-title">設定を編集</h2>
                <button id="admin-close-setting-modal-btn" class="btn-icon-only"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <form id="admin-setting-form">
                <input type="hidden" name="key">
                <div class="form-group">
                    <label>キー</label>
                    <input type="text" name="displayKey" disabled class="form-control" style="width: 100%; margin-bottom: 1rem; opacity: 0.7;">
                </div>
                <div class="form-group">
                    <label>値</label>
                    <input type="text" id="admin-setting-value-input" name="value" required class="form-control" style="width: 100%; margin-bottom: 1rem;">
                </div>
                <div class="form-group">
                    <label>カテゴリ</label>
                    <input type="text" name="category" class="form-control" style="width: 100%; margin-bottom: 1rem;">
                </div>
                <div class="form-group">
                    <label>説明</label>
                    <textarea name="description" class="form-control" style="width: 100%; min-height: 80px; margin-bottom: 1rem;"></textarea>
                </div>
                <div class="modal-footer" style="display: flex; justify-content: flex-end; gap: 1rem;">
                    <button type="button" id="admin-cancel-setting-btn" class="btn-secondary" style="padding: 0.5rem 1.5rem; border-radius: 20px;">キャンセル</button>
                    <button type="submit" class="btn-primary" style="padding: 0.5rem 1.5rem; border-radius: 20px;">保存</button>
                </div>
            </form>
        </div>
    </div>

